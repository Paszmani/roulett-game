{
  "name": "roleta-personalizavel",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:sync": "expo prebuild -p android",
    "android:apk": "expo prebuild -p android && node ./scripts/build-android.js",
    "android:open": "node ./scripts/open-android.js",
    "web": "expo start --web",
    "build:web": "expo export -p web && node ./scripts/spa-fallback.js && workbox generateSW workbox-config.js",
    "sw": "workbox generateSW workbox-config.js",
    "predeploy": "expo export -p web && node ./scripts/spa-fallback.js && workbox generateSW workbox-config.js",
    "deploy": "gh-pages --nojekyll -d dist",
    "lint": "expo lint",
    "ios": "expo run:ios",
    "electron:web": "expo export -p web --output-dir electron/web",
    "electron:start": "npm --prefix electron run start",
    "electron:dev": "npm run electron:web && npm run electron:start",
    "electron:dist": "npm run electron:web && npm --prefix electron run dist",
    "android:sync:clean": "expo prebuild -p android --clean"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.1",
    "@expo-google-fonts/montserrat": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.1",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.0",
    "expo-haptics": "~15.0.0",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-system-ui": "~6.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.1"
  },
  "private": true
}
